<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IdeaLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IdeaLauncher"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="IdeaLauncher">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側 -->

        <StackPanel
            Grid.Column="0"
            Margin="10"
            Spacing="10">

            <TextBlock
                Text="Instances"
                FontSize="24"/>

            <ListView
                x:Name="InstanceList"
                DoubleTapped="InstanceList_DoubleTapped"
                SelectionChanged="InstanceList_SelectionChanged"
                Height="400"/>

            <Button
                Content="+ 新增實例"
                Click="CreateInstance_Click"/>

        </StackPanel>

        <!-- 右側 -->

        <StackPanel
            Grid.Column="1"
            Margin="20"
            Spacing="12">

            <TextBlock
                Text="Instance Details"
                FontSize="24"/>

            <TextBlock
                Text="名稱"/>

            <TextBlock
                x:Name="NameText"/>

            <TextBlock
                Text="版本"/>

            <TextBlock
                x:Name="VersionText"/>

            <TextBlock
                Text="Loader"/>

            <TextBlock
                x:Name="LoaderText"/>

            <TextBlock
                Text="RAM"/>

            <TextBlock
                x:Name="RamText"/>

            <!--<Button
                Content="Test Java"
