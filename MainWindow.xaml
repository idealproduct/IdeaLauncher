            <Button
                Content="測試解壓"
                Click="TestExtract_Click"/>

            <Button
                Content="安裝測試 Runtime"
                Click="InstallRuntime_Click"/>

            -->
            <TextBlock
                x:Name="ProgressText"
                Text="0%" />
            <!--

            <Button
                Content="測試進度下載"
                Click="TestDownloadProgress_Click"/>-->

            <Button
                Content="啟動測試"
                Click="Launch_Click"/>

            <Button
                Content="Extract Natives"
                Click="ExtractNatives_Click"/>

            <Button
                Content="Show Natives"
                Click="ShowNatives_Click"/>

            <Button
                Content="Java Version"
                Click="JavaVersion_Click"/>

            <Button
                Content="解壓Java"
                Click="ExtractJava_Click"/>

            <Button
                Content="下載Java"
                Click="DownloadJava_Click"/>

            <!--
            <Button
                Content="檢查Java"
