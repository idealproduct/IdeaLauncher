<Page
    x:Class="IdeaLauncher.Views.InstanceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Width="80" Height="80" Background="{ThemeResource ControlAltFillColorSecondaryBrush}">
                <Image Source="{x:Bind SelectedItem.ImagePath, Mode=OneWay}" Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
                <TextBlock Text="{x:Bind SelectedItem.Name, Mode=OneWay}" FontSize="24" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{x:Bind SelectedItem.MinecraftVersion, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="|" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind SelectedItem.Loader, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                <Button Click="GoBack_Click" ToolTipService.ToolTip="返回主頁面">
                    <FontIcon Glyph="&#xE72B;"/>
                </Button>
                <Button Click="LaunchGame_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,12,24,12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE768;"/>
                        <TextBlock Text="啟動遊戲" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <SelectorBar x:Name="DetailSelectorBar" Grid.Row="0" SelectionChanged="DetailSelectorBar_SelectionChanged">
                <SelectorBarItem x:Name="SettingsTab" Text="基本設定" IsSelected="True" Icon="Setting"/>
                <SelectorBarItem x:Name="ModsTab" Text="模組管理 (Mods)" Icon="Folder"/>
                <SelectorBarItem x:Name="LogsTab" Text="遊戲日誌" Icon="Document"/>
            </SelectorBar>

            <Grid Grid.Row="1" Margin="0,16,0,0">

                <ScrollViewer x:Name="SettingsContent" Visibility="Visible">
                    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="記憶體配置 (RAM)" FontWeight="SemiBold"/>
                                <Slider Minimum="1024" Maximum="16384" StepFrequency="512" 
                                        Value="{x:Bind SelectedItem.RamMB, Mode=TwoWay}"/>
                                <TextBlock Text="{x:Bind SelectedItem.RamMB, Mode=OneWay}" 
                                           HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="自訂 Java 路徑" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" Grid.Column="0" PlaceholderText="預設（自動檢測）" Margin="0,0,8,0"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="瀏覽..."/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="ModsContent" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE8B7;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="所有模組都將顯示於此" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button Content="開啟 Mods 資料夾" HorizontalAlignment="Center" Click="OpenModsFolder_Click"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="LogsContent" Visibility="Collapsed">
                    <TextBox x:Name="LogTextBox" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" 
                             FontFamily="Consolas" PlaceholderText="遊戲尚未啟動，暫無日誌輸出..."
                             Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Page>