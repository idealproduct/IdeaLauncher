<Page
    x:Class="IdeaLauncher.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IdeaLauncher" xmlns:Model="using:IdeaLauncher.Models">

    <Grid RowDefinitions="Auto, *">

        <CommandBar Grid.Row="0" Background="Transparent" IsOpen="False">
            <AppBarButton Icon="Back" Label="返回上一頁" Click="Back_Click"/>
            <AppBarButton Icon="Add" Label="創建" Click="CreateInstance_Click"/>
            <AppBarButton Icon="Download" Label="導入"/>
            <AppBarButton Icon="Bold" Label="建立群組"/>
            <CommandBar.SecondaryCommands>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <GridView 
            Grid.Row="1" 
            x:Name="InstanceGridView"
            Padding="20"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="InstanceGridView_ItemClick"
            DoubleTapped="InstanceGridView_DoubleTapped">

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="Model:InstanceItem">
                    <Grid Width="180" Height="240" Margin="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"/>

                        <Grid RowDefinitions="*, Auto">
                            <Image Grid.Row="0" Source="{x:Bind ImagePath}" Stretch="UniformToFill"/>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Orientation="Horizontal" Background="#80000000" CornerRadius="4" Margin="6" Padding="6,2">
                                <TextBlock Text="{x:Bind MinecraftVersion}" FontSize="12" Foreground="White"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Padding="12" Spacing="4" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Author}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>

        </GridView>
    </Grid>
</Page>