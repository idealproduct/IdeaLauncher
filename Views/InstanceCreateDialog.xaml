<ContentDialog
    x:Class="IdeaLauncher.Views.InstanceCreateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="建立新實例"
    PrimaryButtonText="建立"
    CloseButtonText="取消">

    <StackPanel Spacing="12">

        <TextBox
            x:Name="NameBox"
            Header="名稱"
            PlaceholderText="輸入實例名稱"/>

        <TextBlock Text="Minecraft Version"
                   Margin="0,12,0,4"/>

        <ComboBox
            x:Name="VersionBox"
            PlaceholderText="選擇版本"/>

        <ComboBox
            x:Name="LoaderBox"
            Header="Loader">

            <ComboBoxItem Content="Vanilla"/>
            <ComboBoxItem Content="Fabric"/>
            <ComboBoxItem Content="Forge"/>

        </ComboBox>

        <NumberBox
            x:Name="RamBox"
            Header="RAM (MB)"
            Value="4096"/>

    </StackPanel>

</ContentDialog>